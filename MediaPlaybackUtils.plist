<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Filter</key>
    <dict>
        <key>Mode</key>
        <string>Any</string>
        <key>Bundles</key>
        <array>
            <!-- FIX 7 (v1.8.0):
                 УБРАНЫ из списка инжекта приложения, в которых:
                   - нет AVCaptureVideoDataOutput-пайплайна;
                   - крах в swift_getSingletonMetadata из-за гонки
                     objc_copyClassList ↔ Swift/Kotlin metadata init;
                   - подменять видео физически нечем (KYC идёт через
                     встроенные SDK Jumio/Onfido/AmazonRekognition внутри
                     WebView или нативные VNDocumentCameraView).

                 Удалены:
                   * com.amazon.Amazon       (KMM → крах GC Timer thread)
                   * com.paypal.PPClient     (Swift+CoreML → крах)
                   * com.venmo.Venmo, com.cashapp.squarecash
                   * Все банки (Chase / BoA / Wells Fargo / KeyBank / WU)
                   * Mail/scanners/Notes (camera через doc-scanner API)
                   * Uber/Lyft/Duolingo  (нет видео-капчуры)

                 Оставлены:
                   - Камера (нативная)
                   - Мессенджеры с реальной видеосвязью (Telegram, WhatsApp,
                     Messenger, Skype, Viber, Discord, Teams, Hangouts)
                   - Видео-звонки (FaceTime, Zoom, Meet, WebEx, Vonage,
                     RingCentral)
                   - Соцсети с записью видео и сториз (Instagram, Facebook,
                     TikTok, Snapchat, Twitter, Pinterest, Reddit, LinkedIn,
                     Tumblr, BeReal, Locket)
                   - Стриминг (Twitch, YouTube, Uplive, Kick)
                   - Знакомства с фото/видео-верификацией (Tinder, Bumble,
                     Hinge, Grindr, Match, OkCupid)
                   - Браузеры (через BrowserHooks.x — отдельная безопасная
                     ветка после FIX 7)
            -->

            <!-- Камера -->
            <string>com.apple.camera</string>

            <!-- Браузеры — основные процессы -->
            <string>com.apple.mobilesafari</string>
            <string>com.google.chrome.ios</string>
            <string>com.google.chrome.ios.SafariViewService</string>
            <string>com.brave.ios.browser</string>
            <string>com.brave.ios.browser.SafariViewService</string>
            <string>com.opera.Opera</string>
            <string>com.firefox.ios</string>
