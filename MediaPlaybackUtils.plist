<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Filter</key>
    <dict>
        <!-- Загружаемся во ВСЕ процессы, использующие AVFoundation
             (камера, видео, аудио). Это покрывает абсолютно все
             приложения с подменой камеры: Amazon, PayPal, банки,
             KYC-SDK, мессенджеры, стриминг, соцсети, браузеры. -->
        <key>Bundles</key>
        <array>
            <string>com.apple.AVFoundation</string>
        </array>

        <!-- Не трогаем системные сервисы и UI-инфраструктуру -->
        <key>Executables</key>
        <array>
            <string>SpringBoard</string>
            <string>backboardd</string>
            <string>mediaserverd</string>
            <string>assertiond</string>
            <string>locationd</string>
            <string>searchd</string>
            <string>spotlightd</string>
            <string>callservicesd</string>
            <string>identityservicesd</string>
        </array>

        <key>Mode</key>
        <string>Any</string>
    </dict>
</dict>
</plist>
